# 공공데이터포털 인증키 (https://www.data.go.kr 회원가입 → 활용신청)
# 활용신청할 API:
#   - 중앙선거관리위원회_코드 정보       (CommonCodeService)
#   - 중앙선거관리위원회_선거공약 정보   (ElecPrmsInfoInqireService)
#   - 중앙선거관리위원회_후보자 정보     (PofelcddInfoInqireService)
NEC_API_KEY=your_decoded_service_key_here

# HuggingFace
HF_TOKEN=hf_xxxxxxxxxxxx
HF_DATASET_REPO=electionmcp/korea-local-election-2026

# 9회 전국동시지방선거 sgId (CommonCodeService 로 검증 후 확정)
SG_ID=20260603

# 후보자 단계: preliminary(예비, ~5/14) | official(정식, 5/15~)
CANDIDATE_STAGE=preliminary

# Rate limiting
NEC_RPS=5
PDF_CONCURRENCY=10

# 데이터 경로
DATA_DIR=./data
PDF_CACHE_DIR=./data/pdfs
PARQUET_DIR=./data/parquet

# MCP 서버
MCP_HOST=0.0.0.0
MCP_PORT=8765
